{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": "off",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@tauri-apps/api/core",
            "message": "Use src/lib/invoke.ts instead."
          },
          {
            "name": "@tauri-apps/api/event",
            "message": "Use src/lib/listen.ts instead."
          },
          {
            "name": "@tauri-apps/plugin-opener",
            "message": "Use isTauri guard in src/main.tsx instead."
          }
        ]
      }
    ]
  },
  "settings": {
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "version": "19",
      "componentWrapperFunctions": []
    }
  },
  "env": {
    "browser": true
  },
  "globals": {},
  "ignorePatterns": ["dist", "src-tauri/gen", "src-tauri/target"],
  "overrides": [
    {
      "files": ["src/lib/invoke.ts", "src/lib/listen.ts", "src/lib/openUrl.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
